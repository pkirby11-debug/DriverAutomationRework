@{
    RootModule        = 'DriverAutomationTool.psm1'
    ModuleVersion     = '1.11.0'
    GUID              = 'a3f7b2c1-4d5e-6f78-9a0b-1c2d3e4f5678'
    Author            = 'Driver Automation Tool Contributors'
    Description       = 'Automates downloading, packaging, and distributing Dell and Lenovo drivers and BIOS updates for SCCM/ConfigMgr environments. 1.11.0 fixes Dell per-model catalog staleness so individual drivers like the latest Intel Arc revision (A05) are picked up immediately instead of waiting on a 24h TTL: -ForceRefresh now propagates from Invoke-DATSync / Get-DATDriverPack / Get-DATBIOSUpdate into Update-DellModelCatalog, the per-model catalog default TTL drops from 24h to 6h, and the Driver Updates pre-download phase now surfaces the top failure reasons (and the per-DUP error) on each skip line so cascading download failures are diagnosable from the log instead of all showing as a generic "did not produce a usable file".'
    PowerShellVersion = '5.1'
    FunctionsToExport = @(
        'Get-DATDriverPack'
        'Get-DATBIOSUpdate'
