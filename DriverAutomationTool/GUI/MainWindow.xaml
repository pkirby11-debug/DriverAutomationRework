<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    Title="Driver Automation Tool"
    Height="720" Width="1050"
    MinHeight="600" MinWidth="900"
    WindowStartupLocation="CenterScreen"
    FontFamily="Segoe UI" FontSize="12"
    Background="{DynamicResource WinBg}"
    TextOptions.TextFormattingMode="Display">

    <!--
        DriverAutomationTool main window (WPF).
        Pure layout: every interactive control carries an x:Name that the event
        layer (MainWindow.ps1) resolves into the $Controls hashtable. Colours come
        from the theme brush resources below (light defaults); Set-DATWindowTheme
        swaps them at runtime to follow the Windows light/dark app setting. Layout
        uses Grid/DockPanel star-sizing so it scales with the window.
    -->

    <Window.Resources>
        <!-- ===== Theme brushes (light defaults; replaced at runtime for dark) ===== -->
        <SolidColorBrush x:Key="WinBg" Color="#FFF3F3F3" />
        <SolidColorBrush x:Key="PanelBg" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="CtrlBg" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="GridBg" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="GridAltBg" Color="#FFF7F9FB" />
        <SolidColorBrush x:Key="GridHeaderBg" Color="#FFEFEFEF" />
        <SolidColorBrush x:Key="Fg" Color="#FF1B1B1B" />
        <SolidColorBrush x:Key="SubtleFg" Color="#FF6E6E6E" />
        <SolidColorBrush x:Key="BorderClr" Color="#FFD0D0D0" />
        <SolidColorBrush x:Key="StatusBg" Color="#FFE8E8E8" />

        <!-- Accent is theme-independent -->
        <SolidColorBrush x:Key="AccentBg" Color="#FF0078D4" />

        <!-- Accent (primary action) button -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBg}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF106EBE" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#FF7A7A7A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Standard (secondary) button -->
        <Style x:Key="StandardButton" TargetType="Button">
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Background" Value="{DynamicResource CtrlBg}" />
            <Setter Property="Foreground" Value="{DynamicResource Fg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderClr}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Padding" Value="8" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Background" Value="{DynamicResource PanelBg}" />
            <Setter Property="Foreground" Value="{DynamicResource Fg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderClr}" />
        </Style>

        <Style TargetType="Label">
            <Setter Property="Padding" Value="0,0,4,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource Fg}" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="3,2" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="{DynamicResource CtrlBg}" />
            <Setter Property="Foreground" Value="{DynamicResource Fg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderClr}" />
            <Setter Property="CaretBrush" Value="{DynamicResource Fg}" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="24" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="{DynamicResource CtrlBg}" />
            <Setter Property="Foreground" Value="{DynamicResource Fg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderClr}" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,4" />
            <Setter Property="Foreground" Value="{DynamicResource Fg}" />
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,4,12,4" />
            <Setter Property="Foreground" Value="{DynamicResource Fg}" />
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="{DynamicResource CtrlBg}" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="Background" Value="{DynamicResource GridBg}" />
            <Setter Property="RowBackground" Value="{DynamicResource GridBg}" />
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource GridAltBg}" />
            <Setter Property="Foreground" Value="{DynamicResource Fg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderClr}" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderClr}" />
            <Setter Property="SelectionMode" Value="Extended" />
            <Setter Property="SelectionUnit" Value="FullRow" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource GridHeaderBg}" />
            <Setter Property="Foreground" Value="{DynamicResource Fg}" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderClr}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="{DynamicResource Fg}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- ===================== HEADER ===================== -->
        <Border DockPanel.Dock="Top" Height="50" Background="{DynamicResource AccentBg}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                <TextBlock Text="Driver Automation Tool" Foreground="White"
                           FontSize="20" FontWeight="Bold" VerticalAlignment="Center" />
                <TextBlock x:Name="VersionLabel" Text="" Foreground="#FFE6F1FB"
                           FontSize="12" Margin="12,0,0,0" VerticalAlignment="Bottom"
                           Padding="0,0,0,4" />
            </StackPanel>
        </Border>

        <!-- ===================== STATUS BAR (very bottom) ===================== -->
        <StatusBar DockPanel.Dock="Bottom" Background="{DynamicResource StatusBg}">
            <StatusBarItem>
                <TextBlock x:Name="StatusStripLabel" Text="Ready" Foreground="{DynamicResource Fg}" />
            </StatusBarItem>
        </StatusBar>

        <!-- ===================== BOTTOM ACTION BAR ===================== -->
        <Border DockPanel.Dock="Bottom" Height="56" Background="{DynamicResource StatusBg}"
                BorderBrush="{DynamicResource BorderClr}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                <Button x:Name="StartButton" Content="Start Sync" Style="{StaticResource AccentButton}"
                        Width="170" Height="38" FontSize="14" Margin="0,0,10,0" />
                <Button x:Name="StopButton" Content="Stop" Style="{StaticResource StandardButton}"
                        Width="80" Height="38" Margin="0,0,10,0" IsEnabled="False" />
                <Button x:Name="SaveSettingsButton" Content="Save Settings" Style="{StaticResource StandardButton}"
                        Width="120" Height="38" Margin="0,0,10,0" />
                <Button x:Name="HealthCheckButton" Content="Health Check" Style="{StaticResource StandardButton}"
                        Width="120" Height="38" />
            </StackPanel>
        </Border>

        <!-- ===================== TABS ===================== -->
        <TabControl x:Name="TabControl" Margin="6" Padding="0" Background="{DynamicResource WinBg}"
                    BorderBrush="{DynamicResource BorderClr}">

            <!-- ============ Tab 1: Models ============ -->
            <TabItem Header="Models">
                <DockPanel Margin="10" LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top">
                        <!-- Manufacturers -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Label Content="Manufacturers:" Width="110" />
                            <CheckBox x:Name="DellCheckBox" Content="Dell" IsChecked="True" Margin="0,0,16,0" />
                            <CheckBox x:Name="LenovoCheckBox" Content="Lenovo" IsChecked="True" Margin="0,0,16,0" />
                            <CheckBox x:Name="MicrosoftCheckBox" Content="Microsoft" />
                        </StackPanel>
                        <!-- OS / Arch / Type -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Label Content="Operating System:" Width="110" />
                            <ComboBox x:Name="OsCombo" Width="190" Margin="0,0,16,0" />
                            <Label Content="Architecture:" />
                            <ComboBox x:Name="ArchCombo" Width="90" Margin="0,0,16,0" SelectedIndex="0">
                                <sys:String>x64</sys:String>
                                <sys:String>ARM64</sys:String>
                            </ComboBox>
                            <Label Content="Package Type:" />
                            <ComboBox x:Name="TypeCombo" Width="220" SelectedIndex="0">
                                <sys:String>Drivers</sys:String>
                                <sys:String>BIOS Updates</sys:String>
                                <sys:String>Drivers + BIOS</sys:String>
                                <sys:String>Driver Updates (Catalog Only)</sys:String>
                            </ComboBox>
                        </StackPanel>
                        <!-- Search / actions -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Label Content="Search Models:" Width="110" />
                            <TextBox x:Name="SearchBox" Width="260" Margin="0,0,12,0" />
                            <Button x:Name="RefreshButton" Content="Refresh Models" Style="{StaticResource StandardButton}" Width="120" Margin="0,0,8,0" />
                            <Button x:Name="SelectAllButton" Content="Select All" Style="{StaticResource StandardButton}" Width="80" Margin="0,0,8,0" />
                            <Button x:Name="SelectNoneButton" Content="Select None" Style="{StaticResource StandardButton}" Width="90" Margin="0,0,12,0" />
                            <CheckBox x:Name="KnownModelsCheckBox" Content="Select Known Models" IsEnabled="False" />
                        </StackPanel>
                    </StackPanel>

                    <DataGrid x:Name="ModelGrid">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="" Width="30"
                                Binding="{Binding Selected, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Header="Manufacturer" Width="110" IsReadOnly="True" Binding="{Binding Manufacturer}" />
                            <DataGridTextColumn Header="Model" Width="*" IsReadOnly="True" Binding="{Binding Model}" />
                            <DataGridTextColumn Header="System ID / Machine Type" Width="200" IsReadOnly="True" Binding="{Binding SystemID}" />
                            <DataGridTextColumn Header="Platform" Width="90" IsReadOnly="True" Binding="{Binding Platform}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- ============ Tab 2: SCCM Settings ============ -->
            <TabItem Header="SCCM Settings">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="470" />
                        <ColumnDefinition Width="*" MinWidth="380" />
                    </Grid.ColumnDefinitions>

                    <!-- Left column: connection, paths, options -->
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <GroupBox Header="ConfigMgr Connection">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Label Grid.Row="0" Grid.Column="0" Content="Site Server:" />
                                <TextBox x:Name="SiteServerInput" Grid.Row="0" Grid.Column="1" Margin="0,3" />
                                <Label Grid.Row="1" Grid.Column="0" Content="Site Code:" />
                                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,3">
                                    <TextBox x:Name="SiteCodeInput" Width="80" MaxLength="3" CharacterCasing="Upper" />
                                    <CheckBox x:Name="UseSSLCheckBox" Content="Use SSL (WinRM over HTTPS)" Margin="12,0,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,6,0,0">
                                    <Button x:Name="ConnectButton" Content="Connect" Style="{StaticResource StandardButton}" Width="100" />
                                    <TextBlock x:Name="ConnStatusLabel" Text="Not Connected" Foreground="{DynamicResource SubtleFg}"
                                               VerticalAlignment="Center" Margin="12,0,0,0" />
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Package Paths">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Label Grid.Row="0" Grid.Column="0" Content="Download Path:" />
                                <TextBox x:Name="DownloadPathInput" Grid.Row="0" Grid.Column="1" Margin="0,3" />
                                <Button x:Name="DLBrowseButton" Grid.Row="0" Grid.Column="2" Content="..." Width="36" Margin="6,3,0,3" Style="{StaticResource StandardButton}" />
                                <Label Grid.Row="1" Grid.Column="0" Content="Package Path:" />
                                <TextBox x:Name="PackagePathInput" Grid.Row="1" Grid.Column="1" Margin="0,3" />
                                <Button x:Name="PkgBrowseButton" Grid.Row="1" Grid.Column="2" Content="..." Width="36" Margin="6,3,0,3" Style="{StaticResource StandardButton}" />
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Options">
                            <StackPanel>
                                <WrapPanel>
                                    <CheckBox x:Name="RemoveLegacyCheckBox" Content="Remove superseded packages" Width="250" />
                                    <CheckBox x:Name="EnableBDRCheckBox" Content="Enable Binary Diff. Replication" IsChecked="True" Width="230" />
                                    <CheckBox x:Name="CleanSourceCheckBox" Content="Clean source content of removed packages" Width="290" />
                                    <CheckBox x:Name="CleanDownloadsCheckBox" Content="Clean up download files" Width="250" />
                                    <CheckBox x:Name="CleanUnusedCheckBox" Content="Clean up unused drivers" IsEnabled="False" Width="230" />
                                    <CheckBox x:Name="UpdateIndividualCheckBox" Content="Update individual drivers (Dell)" IsEnabled="False" Width="290" />
                                    <CheckBox x:Name="VerifyHashCheckBox" Content="Verify download hash (Dell)" Width="250" />
                                </WrapPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Label Content="Deployment Platform:" Width="130" />
                                    <ComboBox x:Name="DeployPlatformCombo" Width="240" SelectedIndex="0">
                                        <sys:String>ConfigMgr - Standard Pkg</sys:String>
                                        <sys:String>ConfigMgr - Driver Pkg</sys:String>
                                        <sys:String>ConfigMgr - Application</sys:String>
                                        <sys:String>ConfigMgr - Standard Pkg (Test)</sys:String>
                                        <sys:String>ConfigMgr - Driver Pkg (Test)</sys:String>
                                        <sys:String>ConfigMgr - Application (Test)</sys:String>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <CheckBox x:Name="CompressPackageCheckBox" Content="Compress Package:" Width="130" />
                                    <ComboBox x:Name="CompressionTypeCombo" Width="90" IsEnabled="False" SelectedIndex="0">
                                        <sys:String>ZIP</sys:String>
                                        <sys:String>WIM</sys:String>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>

                    <!-- Right column: distribution points / groups -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <GroupBox Grid.Row="0" Header="Distribution Points">
                            <DataGrid x:Name="DPGrid">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="" Width="30"
                                        Binding="{Binding Selected, UpdateSourceTrigger=PropertyChanged}" />
                                    <DataGridTextColumn Header="Distribution Point" Width="*" IsReadOnly="True" Binding="{Binding Name}" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>
                        <GroupBox Grid.Row="1" Header="Distribution Point Groups">
                            <DataGrid x:Name="DPGGrid">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="" Width="30"
                                        Binding="{Binding Selected, UpdateSourceTrigger=PropertyChanged}" />
                                    <DataGridTextColumn Header="Distribution Point Group" Width="*" IsReadOnly="True" Binding="{Binding Name}" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ============ Tab 3: Progress ============ -->
            <TabItem Header="Progress">
                <DockPanel Margin="10" LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <ProgressBar x:Name="ProgressBar" Height="24" Minimum="0" Maximum="100" />
                        <TextBlock x:Name="StatusLabel" Text="Ready" FontSize="13" Margin="0,8,0,0" Foreground="{DynamicResource Fg}" />
                    </StackPanel>
                    <ListBox x:Name="LogListBox" FontFamily="Consolas" FontSize="12"
                             Background="#FF1E1E1E" Foreground="#FFC8C8C8" BorderBrush="{DynamicResource BorderClr}"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" />
                </DockPanel>
            </TabItem>

            <!-- ============ Tab 4: Package Management ============ -->
            <TabItem Header="Package Management">
                <DockPanel Margin="10" LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top">
                        <WrapPanel Margin="0,0,0,6">
                            <Button x:Name="PkgRefreshButton" Content="Refresh Packages" Style="{StaticResource StandardButton}" Width="130" Margin="0,0,8,0" />
                            <ComboBox x:Name="PkgFilterCombo" Width="150" Margin="0,0,8,0" SelectedIndex="0">
                                <sys:String>All Packages</sys:String>
                                <sys:String>Drivers Only</sys:String>
                                <sys:String>BIOS Only</sys:String>
                            </ComboBox>
                            <Button x:Name="PkgDeleteButton" Content="Remove Selected" Style="{StaticResource StandardButton}" Width="130" Margin="0,0,8,0" Foreground="#FFC42B1C" />
                            <CheckBox x:Name="PkgIncludeDriverPkgsCheckBox" Content="Include Driver Packages" Margin="0,0,16,0" />
                            <Button x:Name="PkgCleanupOverlayButton" Content="Cleanup Overlay TS Packages..." Style="{StaticResource StandardButton}" Width="210" Foreground="#FFC42B1C" />
                        </WrapPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Label Content="Action:" Width="55" />
                            <ComboBox x:Name="PkgActionCombo" Width="220" Margin="0,0,8,0" SelectedIndex="0">
                                <sys:String>Patch Driver Package</sys:String>
                                <sys:String>Move to Production</sys:String>
                                <sys:String>Move to Pilot</sys:String>
                                <sys:String>Mark as Retired</sys:String>
                                <sys:String>Move to Windows 11 24H2</sys:String>
                                <sys:String>Move to Windows 11 23H2</sys:String>
                                <sys:String>Move to Windows 11 22H2</sys:String>
                                <sys:String>Move to Windows 11</sys:String>
                                <sys:String>Move to Windows 10 22H2</sys:String>
                                <sys:String>Move to Windows 10 21H2</sys:String>
                            </ComboBox>
                            <Button x:Name="PkgApplyButton" Content="Apply Action" Style="{StaticResource StandardButton}" Width="110" Margin="0,0,8,0" />
                            <Button x:Name="PkgSelectAllButton" Content="Select All" Style="{StaticResource StandardButton}" Width="90" Margin="0,0,8,0" />
                            <Button x:Name="PkgSelectNoneButton" Content="Select None" Style="{StaticResource StandardButton}" Width="90" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Label Content="Search:" Width="55" />
                            <TextBox x:Name="PkgSearchBox" Width="350" />
                        </StackPanel>
                    </StackPanel>

                    <DataGrid x:Name="PkgGrid">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="" Width="30"
                                Binding="{Binding Selected, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Header="PackageID" Width="80" IsReadOnly="True" Binding="{Binding PackageID}" />
                            <DataGridTextColumn Header="Name" Width="2*" IsReadOnly="True" Binding="{Binding Name}" />
                            <DataGridTextColumn Header="Version" Width="80" IsReadOnly="True" Binding="{Binding Version}" />
                            <DataGridTextColumn Header="Manufacturer" Width="110" IsReadOnly="True" Binding="{Binding Manufacturer}" />
                            <DataGridTextColumn Header="Type" Width="90" IsReadOnly="True" Binding="{Binding PackageType}" />
                            <DataGridTextColumn Header="SourcePath" Width="*" IsReadOnly="True" Binding="{Binding SourcePath}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- ============ Tab 5: Deploy Applications ============ -->
            <TabItem Header="Deploy Applications">
                <DockPanel Margin="10" LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top">
                        <!-- Filters + options row -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="210" />
                                <ColumnDefinition Width="Auto" MinWidth="210" />
                                <ColumnDefinition Width="*" MinWidth="430" />
                            </Grid.ColumnDefinitions>

                            <GroupBox Grid.Column="0" Header="Application Type" Margin="0,0,10,10">
                                <StackPanel>
                                    <CheckBox x:Name="DeployDriverCheckBox" Content="Driver Applications" IsChecked="True" />
                                    <CheckBox x:Name="DeployDriverUpdatesCheckBox" Content="Driver Update Applications" IsChecked="True" />
                                    <CheckBox x:Name="DeployBIOSCheckBox" Content="BIOS Applications" />
                                    <CheckBox x:Name="DeployIncludeTestCheckBox" Content="Include 'Test - ' apps" />
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Grid.Column="1" Header="Manufacturer Filter" Margin="0,0,10,10">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox x:Name="DeployDellCheckBox" Content="Dell" IsChecked="True" Margin="0,4,12,4" />
                                        <CheckBox x:Name="DeployLenovoCheckBox" Content="Lenovo" IsChecked="True" Margin="0,4,12,4" />
                                        <CheckBox x:Name="DeployMicrosoftCheckBox" Content="Microsoft" IsChecked="True" />
                                    </StackPanel>
                                    <Label Content="Model contains:" Margin="0,4,0,0" />
                                    <TextBox x:Name="DeployModelInput" />
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Grid.Column="2" Header="Deployment Options" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Purpose + Action -->
                                    <WrapPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal">
                                        <Label Content="Purpose:" />
                                        <RadioButton x:Name="DeployPurposeAvailableRadio" GroupName="DeployPurpose" Content="Available" IsChecked="True" />
                                        <RadioButton x:Name="DeployPurposeRequiredRadio" GroupName="DeployPurpose" Content="Required" />
                                        <Label Content="Action:" Margin="12,0,0,0" />
                                        <RadioButton x:Name="DeployActionInstallRadio" GroupName="DeployAction" Content="Install" IsChecked="True" />
                                        <RadioButton x:Name="DeployActionUninstallRadio" GroupName="DeployAction" Content="Uninstall" />
                                    </WrapPanel>

                                    <!-- User notification -->
                                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,4,0,0">
                                        <Label Content="User notification:" Width="105" />
                                        <ComboBox x:Name="DeployUserNotifCombo" Width="220" SelectedIndex="0">
                                            <sys:String>DisplayAll</sys:String>
                                            <sys:String>DisplaySoftwareCenterOnly</sys:String>
                                            <sys:String>HideAll</sys:String>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- Schedule -->
                                    <WrapPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,4,0,0">
                                        <CheckBox x:Name="DeployScheduleCheck" Content="Schedule" Width="105" />
                                        <Label Content="Avail:" />
                                        <DatePicker x:Name="DeployAvailablePicker" Width="120" IsEnabled="False" />
                                        <TextBox x:Name="DeployAvailableTime" Width="55" Margin="4,0,0,0" Text="00:00" IsEnabled="False" />
                                        <Label Content="Deadline:" Margin="12,0,0,0" />
                                        <DatePicker x:Name="DeployDeadlinePicker" Width="120" IsEnabled="False" />
                                        <TextBox x:Name="DeployDeadlineTime" Width="55" Margin="4,0,0,0" Text="00:00" IsEnabled="False" />
                                    </WrapPanel>

                                    <!-- MW behavior -->
                                    <WrapPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,4,0,0">
                                        <CheckBox x:Name="DeployOverrideSWCheck" Content="Install outside maintenance window" Margin="0,4,18,4" />
                                        <CheckBox x:Name="DeployRebootOutsideSWCheck" Content="Restart outside maintenance window" />
                                    </WrapPanel>

                                    <!-- Create MW -->
                                    <CheckBox Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" x:Name="DeployCreateMWCheck"
                                              Content="Create / ensure maintenance window on collection" Margin="0,6,0,0" />
                                    <WrapPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="18,4,0,0">
                                        <Label Content="Start:" />
                                        <DatePicker x:Name="DeployMWStartPicker" Width="120" IsEnabled="False" />
                                        <TextBox x:Name="DeployMWStartTime" Width="55" Margin="4,0,0,0" Text="22:00" IsEnabled="False" />
                                        <Label Content="Dur:" Margin="10,0,0,0" />
                                        <TextBox x:Name="DeployMWHoursNUD" Width="40" Text="4" IsEnabled="False" />
                                        <Label Content="h" />
                                        <TextBox x:Name="DeployMWMinutesNUD" Width="40" Text="0" IsEnabled="False" />
                                        <Label Content="m" />
                                        <Label Content="Recur:" Margin="10,0,0,0" />
                                        <ComboBox x:Name="DeployMWRecurCombo" Width="90" IsEnabled="False">
                                            <sys:String>None</sys:String>
                                            <sys:String>Daily</sys:String>
                                            <sys:String>Weekly</sys:String>
                                        </ComboBox>
                                        <Label Content="Day:" Margin="10,0,0,0" />
                                        <ComboBox x:Name="DeployMWDayCombo" Width="100" IsEnabled="False">
                                            <sys:String>Sunday</sys:String>
                                            <sys:String>Monday</sys:String>
                                            <sys:String>Tuesday</sys:String>
                                            <sys:String>Wednesday</sys:String>
                                            <sys:String>Thursday</sys:String>
                                            <sys:String>Friday</sys:String>
                                            <sys:String>Saturday</sys:String>
                                        </ComboBox>
                                    </WrapPanel>
                                </Grid>
                            </GroupBox>
                        </Grid>

                        <!-- Collection picker (stretches with the window) -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="Target Collection:" Width="115" />
                            <ComboBox x:Name="DeployCollectionCombo" Grid.Column="1" IsEditable="True" Margin="0,0,10,0" />
                            <Button x:Name="DeployRefreshCollectionsButton" Grid.Column="2" Content="Refresh Collections" Style="{StaticResource StandardButton}" Width="140" />
                        </Grid>

                        <!-- App action row -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Button x:Name="DeployRefreshAppsButton" Content="Refresh Applications" Style="{StaticResource StandardButton}" Width="150" Margin="0,0,8,0" />
                            <Button x:Name="DeploySelectAllButton" Content="Select All" Style="{StaticResource StandardButton}" Width="90" Margin="0,0,8,0" />
                            <Button x:Name="DeploySelectNoneButton" Content="Select None" Style="{StaticResource StandardButton}" Width="90" Margin="0,0,12,0" />
                            <Label Content="Search:" />
                            <TextBox x:Name="DeployAppsSearchBox" Width="280" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button x:Name="DeployButton" Content="Deploy Selected" Style="{StaticResource AccentButton}" Width="160" Height="28" Margin="0,0,12,0" />
                            <TextBlock x:Name="DeployStatusLabel" VerticalAlignment="Center" Foreground="{DynamicResource SubtleFg}"
                                       Text="Connect to ConfigMgr to populate collections, then click Refresh Applications." />
                        </StackPanel>
                    </StackPanel>

                    <DataGrid x:Name="DeployAppsGrid">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="" Width="30"
                                Binding="{Binding Selected, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Header="Name" Width="2*" IsReadOnly="True" Binding="{Binding Name}" />
                            <DataGridTextColumn Header="Version" Width="90" IsReadOnly="True" Binding="{Binding Version}" />
                            <DataGridTextColumn Header="Manufacturer" Width="110" IsReadOnly="True" Binding="{Binding Manufacturer}" />
                            <DataGridTextColumn Header="Kind" Width="90" IsReadOnly="True" Binding="{Binding Kind}" />
                            <DataGridTextColumn Header="LastModified" Width="*" IsReadOnly="True" Binding="{Binding LastModified}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
